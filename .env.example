# Copy this file to .env.local for local development.
# Keep real secrets out of Git. Use dummy values here only.

APP_ENV=development
APP_NAME=final-project
PUBLIC_APP_URL=http://localhost:3000

# Example-only values. Replace locally and never commit real credentials.
EXAMPLE_API_TOKEN=dummy-token-replace-locally
DATABASE_URL=postgresql://dummy_user:dummy_password@localhost:5432/dummy_db
